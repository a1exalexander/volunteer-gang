---
import Layout from '../layouts/Layout.astro';
import TemplateStudio from '../components/TemplateStudio.astro';
import { getEntry } from 'astro:content';

const [fundEntry, templatesEntry] = await Promise.all([
  getEntry('fundraiser', 'active'),
  getEntry('templatesPage', 'templates'),
]);
if (!fundEntry || !templatesEntry) throw new Error('Missing content: fundraiser/active or templatesPage/templates');
const fund = fundEntry.data;
const page = templatesEntry.data;
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
  active="templates"
>
  <TemplateStudio fund={fund} page={page} />
</Layout>
