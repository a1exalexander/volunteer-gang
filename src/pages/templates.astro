---
import Layout from '../layouts/Layout.astro';
import TemplateStudio from '../components/TemplateStudio.astro';
import { getEntry } from 'astro:content';

const fundEntry = await getEntry('fundraiser', 'active');
if (!fundEntry) throw new Error('Missing content: fundraiser/active');
const fund = fundEntry.data;
---

<Layout
  title="VG — Шаблони Instagram"
  description="Генератор постів і сторіз у фірмовому стилі Volunteer Gang. Заповни дані збору один раз — і забери готові картинки для Instagram одним кліком."
  active="templates"
>
  <TemplateStudio fund={fund} />
</Layout>
