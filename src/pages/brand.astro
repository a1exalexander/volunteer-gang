---
// Living brand reference — renders the brand book (logo lockups, marks, colour,
// type) from the reusable components in src/components/brand/. noindex; not in
// the site nav. Doubles as a visual regression surface for the components.
import Layout from '../layouts/Layout.astro';
import Logo from '../components/brand/Logo.astro';
import GangMonogram from '../components/brand/GangMonogram.astro';
import VgPatch from '../components/brand/VgPatch.astro';
import Chevrons from '../components/brand/Chevrons.astro';
import { getEntry } from 'astro:content';

const settingsEntry = await getEntry('site', 'settings');
if (!settingsEntry) throw new Error('Missing content: site/settings');
const settings = settingsEntry.data;
const { word1, word2 } = settings.brand;

const palette = [
  { name: 'Фуксія-91', hex: '#FF2E88', use: 'головний · дія', fg: '#0D0C0C', span: true },
  { name: 'Бабл', hex: '#F4A6E3', use: 'заливка літер', fg: '#0D0C0C' },
  { name: 'Кислота', hex: '#C9E400', use: 'кант і акценти', fg: '#0D0C0C' },
  { name: 'Балаклава', hex: '#0D0C0C', use: 'фон і контур', fg: '#F5F1EC', border: true },
  { name: 'Крейда', hex: '#F5F1EC', use: 'текст', fg: '#0D0C0C' },
  { name: 'Пил', hex: '#8A8580', use: 'другорядне', fg: '#0D0C0C' },
];

const faviconSizes = [48, 32, 16];

// Ready-made icon files in public/ — offered as direct downloads (no capture).
const iconDownloads = [
  { label: 'SVG', href: '/favicon.svg' },
  { label: '16', href: '/favicon-16.png' },
  { label: '32', href: '/favicon-32.png' },
  { label: '180', href: '/apple-touch-icon.png' },
  { label: '192', href: '/icon-192.png' },
  { label: '512', href: '/icon-512.png' },
];

// Copyable type specimens (label → sample string) for the Typography section.
const typeSpecimens = {
  head: 'Збір закрито за 6 годин',
  body: 'Купуємо тепловізори для 92-ї ОШБр за прямим запитом бійців. Кожна гривня йде у звіт.',
  num: '₴ 341 500',
};
---

<Layout title="Volunteer Gang — Бренд-бук" description="Логотип, кольори та типографіка Volunteer Gang." ogId="home" noindex>
  <!-- HERO -->
  <section class="section brand-hero">
    <div class="eyebrow">БРЕНД-БУК · V 1.0 · 2026</div>
    <h1 class="brand-h1">
      <Logo word1={word1} word2={word2} graffiti="layered" layout="stack" size={72} gangSize={92} rotate={-5} />
    </h1>
    <p class="brand-lede">{settings.tagline}</p>
  </section>

  <!-- 01 · LOGO -->
  <section class="section">
    <div class="sec-head"><span class="sec-num">01</span><h2 class="sec-title">Логотип</h2></div>
    <div class="brand-grid brand-grid--3">
      <div class="brand-cell">
        <div class="brand-frame" id="dl-logo-main">
          <Logo word1={word1} word2={word2} graffiti="layered" layout="stack" size={30} gangSize={38} rotate={-5} />
        </div>
        <div class="brand-cap">ОСНОВНИЙ · на чорному</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="logo-main" data-track="brand_download" data-evt-asset="logo-main">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="logo-main">⧉ Копіювати</button>
          <span class="tpl-status" data-status="logo-main"></span>
        </div>
      </div>
      <div class="brand-cell">
        <div class="brand-frame brand-frame--pink" id="dl-logo-inverse">
          <Logo word1={word1} word2={word2} graffiti="layered" layout="stack" size={24} gangSize={30} rotate={-5} inverse />
        </div>
        <div class="brand-cap">ІНВЕРСІЯ · на рожевому</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="logo-inverse" data-track="brand_download" data-evt-asset="logo-inverse">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="logo-inverse">⧉ Копіювати</button>
          <span class="tpl-status" data-status="logo-inverse"></span>
        </div>
      </div>
      <div class="brand-cell">
        <div class="brand-frame" id="dl-patch">
          <VgPatch since={settings.since} region={settings.region} />
        </div>
        <div class="brand-cap">ШЕВРОН · монограма VG</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="patch" data-track="brand_download" data-evt-asset="patch">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="patch">⧉ Копіювати</button>
          <span class="tpl-status" data-status="patch"></span>
        </div>
      </div>
    </div>

    <!-- mark / favicon / horizontal -->
    <div class="brand-sub">ЗНАК · ФАВІКОН · ЛОГОТИП З ТЕКСТОМ</div>
    <div class="brand-grid brand-grid--3">
      <div class="brand-cell">
        <div class="brand-frame" id="dl-znak"><GangMonogram size={132} /></div>
        <div class="brand-cap">ЗНАК · іконка застосунку</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="znak" data-track="brand_download" data-evt-asset="znak">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="znak">⧉ Копіювати</button>
          <span class="tpl-status" data-status="znak"></span>
        </div>
      </div>
      <div class="brand-cell">
        <div class="brand-frame brand-favicons">
          {faviconSizes.map((s) => (
            <div class="brand-fav">
              <img src="/favicon.svg" width={s} height={s} alt={`Фавікон ${s}px`} />
              <span class="brand-fav-n">{s}</span>
            </div>
          ))}
        </div>
        <div class="brand-cap">ФАВІКОН · готові файли</div>
        <div class="brand-actions brand-actions--icons">
          {iconDownloads.map((f) => (
            <a class="dl-btn" href={f.href} download data-track="brand_download" data-evt-asset={`icon-${f.label}`}>
              ↓ {f.label}
            </a>
          ))}
        </div>
      </div>
      <div class="brand-cell">
        <div class="brand-frame brand-frame--row" id="dl-lockup">
          <GangMonogram size={84} />
          <Logo word1={word1} word2={word2} graffiti="layered" layout="stack" size={26} gangSize={32} rotate={-5} />
        </div>
        <div class="brand-cap">ЛОГОТИП З ТЕКСТОМ · горизонтальний лок-ап</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="lockup" data-track="brand_download" data-evt-asset="lockup">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="lockup">⧉ Копіювати</button>
          <span class="tpl-status" data-status="lockup"></span>
        </div>
      </div>
    </div>

    <!-- text-only lockups -->
    <div class="brand-grid brand-grid--2">
      <div class="brand-cell">
        <div class="brand-frame" id="dl-logo-stack">
          <Logo word1={word1} word2={word2} graffiti="layered" layout="stack" size={40} gangSize={50} rotate={-5} />
        </div>
        <div class="brand-cap">ЛОГОТИП ТЕКСТОМ · без знака</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="logo-stack" data-track="brand_download" data-evt-asset="logo-stack">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="logo-stack">⧉ Копіювати</button>
          <span class="tpl-status" data-status="logo-stack"></span>
        </div>
      </div>
      <div class="brand-cell">
        <div class="brand-frame" id="dl-logo-inline">
          <Logo word1={word1} word2={word2} graffiti="layered" layout="inline" size={44} gangSize={52} rotate={-5} />
        </div>
        <div class="brand-cap">ЛОГОТИП ТЕКСТОМ · без знака — горизонтальний</div>
        <div class="brand-actions">
          <button type="button" class="dl-btn" data-dl="logo-inline" data-track="brand_download" data-evt-asset="logo-inline">↓ PNG</button>
          <button type="button" class="cp-btn" data-cp="logo-inline">⧉ Копіювати</button>
          <span class="tpl-status" data-status="logo-inline"></span>
        </div>
      </div>
    </div>

    <div class="brand-rules">
      <p><strong>Правило двох голосів.</strong> «VOLUNTEER» — просте біле накреслення без ефектів: дисципліна і звітність. «GANG» — графіті-леттеринг: рожева заливка, чорний контур і обʼємна тінь, салатовий кант.</p>
      <p><strong>Охоронне поле.</strong> Мінімальний відступ навколо логотипа — висота літери «G». Мінімальна ширина — 120 px.</p>
    </div>
  </section>

  <!-- 02 · COLORS -->
  <section class="section">
    <div class="sec-head"><span class="sec-num">02</span><h2 class="sec-title">Кольори</h2></div>
    <div class="brand-swatches">
      {palette.map((c, i) => (
        <button
          type="button"
          class:list={['brand-swatch', { 'is-wide': c.span, 'is-bordered': c.border }]}
          style={`background:${c.hex}; color:${c.fg}`}
          data-copy-hex={c.hex}
          data-for={`hex-${i}`}
          data-track="brand_copy_hex"
          data-evt-hex={c.hex}
          title="Натисніть, щоб скопіювати HEX"
        >
          <div class="brand-swatch-name">{c.name}</div>
          <div class="brand-swatch-hex mono">
            {c.hex} · {c.use}
            <span class="brand-swatch-status" data-status={`hex-${i}`}></span>
          </div>
        </button>
      ))}
    </div>
    <div class="brand-chevrons-row">
      <span id="dl-chevrons" class="brand-chevrons-hold"><Chevrons /></span>
      <span class="mono brand-cap">← вторинний знак · шеврони</span>
      <div class="brand-actions">
        <button type="button" class="dl-btn" data-dl="chevrons" data-track="brand_download" data-evt-asset="chevrons">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="chevrons">⧉ Копіювати</button>
        <span class="tpl-status" data-status="chevrons"></span>
      </div>
    </div>
  </section>

  <!-- 03 · TYPE -->
  <section class="section">
    <div class="sec-head"><span class="sec-num">03</span><h2 class="sec-title">Типографіка</h2></div>
    <div class="brand-grid brand-grid--3">
      <div class="brand-frame brand-type">
        <div class="mono brand-type-k">ЗАГОЛОВКИ · OSWALD</div>
        <div class="brand-type-head">{typeSpecimens.head}</div>
        <div class="brand-actions">
          <button type="button" class="cp-btn" data-copy-text={typeSpecimens.head} data-for="type-head" data-track="brand_copy_text" data-evt-sample="oswald">⧉ Копіювати текст</button>
          <span class="tpl-status" data-status="type-head"></span>
        </div>
      </div>
      <div class="brand-frame brand-type">
        <div class="mono brand-type-k">ТЕКСТ · IBM PLEX SANS</div>
        <p class="brand-type-body">{typeSpecimens.body}</p>
        <div class="brand-actions">
          <button type="button" class="cp-btn" data-copy-text={typeSpecimens.body} data-for="type-body" data-track="brand_copy_text" data-evt-sample="plex-sans">⧉ Копіювати текст</button>
          <span class="tpl-status" data-status="type-body"></span>
        </div>
      </div>
      <div class="brand-frame brand-type">
        <div class="mono brand-type-k">ЦИФРИ · IBM PLEX MONO</div>
        <div class="brand-type-num mono">{typeSpecimens.num}</div>
        <div class="brand-actions">
          <button type="button" class="cp-btn" data-copy-text={typeSpecimens.num} data-for="type-num" data-track="brand_copy_text" data-evt-sample="plex-mono">⧉ Копіювати текст</button>
          <span class="tpl-status" data-status="type-num"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- html-to-image (CDN global) powers PNG export/copy, same as /templates -->
  <script is:inline async src="https://unpkg.com/html-to-image@1.11.13/dist/html-to-image.js"></script>
  <script>
    import '../scripts/brand-export';
  </script>
</Layout>

<style>
  .brand-hero { display: flex; flex-direction: column; gap: 28px; }
  .brand-h1 { margin: 0; }
  .brand-lede { font-size: 22px; font-weight: 500; color: var(--chalk); }

  .brand-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--acid);
    margin: 56px 0 24px;
  }
  .brand-grid { display: grid; gap: 20px; margin-bottom: 20px; }
  .brand-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .brand-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .brand-cell { display: flex; flex-direction: column; gap: 12px; }
  .brand-frame {
    background: var(--card);
    border: 1px solid var(--border);
    min-height: 260px;
    padding: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
  }
  .brand-frame--pink { background: var(--pink); border-color: var(--pink); }
  .brand-frame--row { flex-direction: row; }
  .brand-cap {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--dust);
    letter-spacing: 0.08em;
  }

  .brand-favicons { gap: 24px; align-items: flex-end; }
  .brand-fav { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .brand-fav-n { font-family: var(--font-mono); font-size: 10px; color: var(--dust); }

  .brand-rules { display: flex; gap: 40px; margin-top: 32px; max-width: 900px; flex-wrap: wrap; }
  .brand-rules p { flex: 1; min-width: 260px; font-size: 14px; line-height: 1.6; color: var(--dust); }
  .brand-rules strong { color: var(--chalk); font-weight: 600; }

  .brand-swatches { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .brand-swatch {
    min-height: 180px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    /* now a <button> — reset native chrome, keep the click-to-copy affordance */
    border: none;
    width: 100%;
    font: inherit;
    text-align: left;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    transition: transform 0.12s ease;
  }
  .brand-swatch:hover { transform: translateY(-2px); }
  .brand-swatch:active { transform: translateY(0); }
  .brand-swatch.is-wide { grid-column: span 1; }
  .brand-swatch.is-bordered { border: 1px solid var(--border); }
  .brand-swatch-name { font-family: var(--font-head); font-weight: 700; font-size: 22px; }
  .brand-swatch-hex { font-size: 13px; }
  .brand-swatch-status { margin-left: 8px; font-weight: 600; opacity: 0.85; }
  .brand-chevrons-row { display: flex; align-items: center; gap: 16px; margin-top: 28px; flex-wrap: wrap; }
  .brand-chevrons-hold { display: inline-flex; }

  .brand-type { flex-direction: column; align-items: flex-start; gap: 18px; min-height: 0; }
  .brand-type-k { font-size: 12px; letter-spacing: 0.08em; color: var(--acid); }
  .brand-type-head {
    font-family: var(--font-head);
    font-weight: 700;
    letter-spacing: 0.02em;
    font-size: 34px;
    line-height: 1.05;
    text-shadow: 3px 3px 0 var(--pink);
  }
  .brand-type-body { font-size: 16px; line-height: 1.6; }
  .brand-type-num { font-size: 34px; font-weight: 500; color: var(--pink); }

  /* download / copy action rows (reuse global .dl-btn/.cp-btn/.tpl-status) */
  .brand-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .brand-actions--icons { gap: 8px; }
  a.dl-btn { display: inline-block; text-decoration: none; }

  @media (max-width: 900px) {
    .brand-grid--3, .brand-grid--2, .brand-swatches { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .brand-grid--3, .brand-grid--2, .brand-swatches { grid-template-columns: 1fr; }
    .brand-frame--row { flex-direction: column; }
  }
</style>
