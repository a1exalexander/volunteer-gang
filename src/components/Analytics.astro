---
// Google Analytics 4 (gtag.js). Renders nothing unless PUBLIC_GA_ID is set,
// so local dev and un-configured deploys stay clean.
const gaId = import.meta.env.PUBLIC_GA_ID;
const debug = import.meta.env.PUBLIC_GA_DEBUG === '1';
---

{
  gaId && (
    <Fragment>
      <script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
      <script is:inline define:vars={{ gaId, debug }}>
        {`
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true, debug_mode: debug });
        `}
      </script>
    </Fragment>
  )
}
