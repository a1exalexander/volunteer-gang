---
// Google Analytics 4 (gtag.js). The loader only activates after the visitor
// explicitly accepts analytics consent.
const gaId = import.meta.env.PUBLIC_GA_ID;
const debug = import.meta.env.PUBLIC_GA_DEBUG === '1';
---

{
  gaId && (
    <script is:inline define:vars={{ gaId, debug }}>
      {`
      const consentKey = 'vg-analytics-consent';

      window.loadVolunteerGangAnalytics = window.loadVolunteerGangAnalytics || function () {
        if (window.__vgAnalyticsLoaded) return;
        window.__vgAnalyticsLoaded = true;

        window.dataLayer = window.dataLayer || [];
        function gtag(){ window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true, debug_mode: debug });

        const script = document.createElement('script');
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(script);
      };

      if (window.localStorage.getItem(consentKey) === 'accepted') {
        window.loadVolunteerGangAnalytics();
      }
      `}
    </script>
  )
}
