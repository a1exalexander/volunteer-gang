---
import type { CollectionEntry } from 'astro:content';
import Logo from './brand/Logo.astro';

interface Props {
  settings: CollectionEntry<'site'>['data'];
  ui: CollectionEntry<'ui'>['data'];
}

const { settings, ui } = Astro.props;
---

<footer class="site-footer">
  <div class="container site-footer-inner">
    <div class="footer-logo">
      <Logo
        word1={settings.brand.word1}
        word2={settings.brand.word2}
        graffiti="layered"
        layout="inline"
        size={22}
        gangSize={26}
        rotate={-4}
      />
    </div>
    <div class="footer-right">
      <a href="/brand" class="footer-link" rel="nofollow">{ui.footerBrandBookLabel}</a>
      <div class="footer-tag">{settings.footerTagline}</div>
    </div>
  </div>
</footer>
