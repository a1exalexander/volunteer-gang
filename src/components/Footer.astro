---
import type { CollectionEntry } from 'astro:content';
import Logo from './brand/Logo.astro';

interface Props {
  settings: CollectionEntry<'site'>['data'];
}

const { settings } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-logo">
    <Logo
      word1={settings.brand.word1}
      word2={settings.brand.word2}
      graffiti="layered"
      layout="inline"
      heart
      size={22}
      gangSize={26}
      rotate={-4}
    />
  </div>
  <div class="footer-right">
    <a href="/brand" class="footer-link" rel="nofollow">БРЕНД-БУК</a>
    <div class="footer-tag">{settings.footerTagline}</div>
  </div>
</footer>
