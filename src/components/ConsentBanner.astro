---
// Cookie/analytics consent banner. Only meaningful when GA is configured, but
// harmless otherwise. Remembers the choice in localStorage and flips GA's
// Consent Mode on accept.
const gaId = import.meta.env.PUBLIC_GA_ID;
---

{
  gaId && (
    <div class="consent" id="vg-consent" hidden>
      <p class="consent-text">
        Ми використовуємо аналітику, щоб розуміти, які збори працюють краще. Приймаєш?
      </p>
      <div class="consent-actions">
        <button type="button" class="btn btn-primary btn--sm" data-consent="accept">Прийняти</button>
        <button type="button" class="ghost-btn" data-consent="decline">Відхилити</button>
      </div>
    </div>
  )
}

<style>
  .consent {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: 16px;
    max-width: 520px;
    margin-inline: auto;
    z-index: 100;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .consent-text {
    margin: 0;
    flex: 1;
    min-width: 220px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--dust);
  }
  .consent-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
</style>

<script>
  const KEY = 'vg-consent';
  const banner = document.getElementById('vg-consent');
  if (banner) {
    let choice: string | null = null;
    try {
      choice = localStorage.getItem(KEY);
    } catch (e) {
      /* ignore */
    }
    if (!choice) banner.hidden = false;

    const decide = (value: 'granted' | 'denied') => {
      try {
        localStorage.setItem(KEY, value);
      } catch (e) {
        /* ignore */
      }
      const gtag = (window as unknown as { gtag?: (...a: unknown[]) => void }).gtag;
      if (value === 'granted' && typeof gtag === 'function') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }
      banner.hidden = true;
    };

    banner
      .querySelector('[data-consent="accept"]')
      ?.addEventListener('click', () => decide('granted'));
    banner
      .querySelector('[data-consent="decline"]')
      ?.addEventListener('click', () => decide('denied'));
  }
</script>
