---
import type { CollectionEntry } from 'astro:content';

interface Props {
  ui: CollectionEntry<'ui'>['data'];
}

const { ui } = Astro.props;
---

<aside class="consent-banner" data-consent-banner hidden>
  <div class="consent-copy">
    <div class="consent-kicker">{ui.consent.kicker}</div>
    <p>{ui.consent.body}</p>
  </div>

  <div class="consent-actions">
    <button type="button" class="btn btn-primary btn--sm" data-consent-accept>{ui.consent.acceptLabel}</button>
    <button type="button" class="consent-btn" data-consent-decline>{ui.consent.declineLabel}</button>
  </div>
</aside>

<script is:inline>
  const consentKey = 'vg-analytics-consent';
  const banner = document.querySelector('[data-consent-banner]');
  const acceptBtn = document.querySelector('[data-consent-accept]');
  const declineBtn = document.querySelector('[data-consent-decline]');
  const consentValue = window.localStorage.getItem(consentKey);

  if (banner && consentValue !== 'accepted' && consentValue !== 'denied') {
    banner.hidden = false;
  }

  acceptBtn?.addEventListener('click', () => {
    window.localStorage.setItem(consentKey, 'accepted');
    banner?.setAttribute('hidden', '');
    window.vgSetAnalyticsConsent?.(true);
  });

  declineBtn?.addEventListener('click', () => {
    window.localStorage.setItem(consentKey, 'denied');
    banner?.setAttribute('hidden', '');
    window.vgSetAnalyticsConsent?.(false);
  });
</script>
