---
import type { CollectionEntry } from 'astro:content';
import Logo from './brand/Logo.astro';

interface Props {
  active?: 'home' | 'templates';
  settings: CollectionEntry<'site'>['data'];
  jarActive?: boolean;
}

const { active, settings, jarActive = false } = Astro.props;
---

<header class="site-header">
  <div class="container site-header-inner">
    <a href="/" class="logo" aria-label={`${settings.brand.word1} ${settings.brand.word2}`}>
      <Logo
        word1={settings.brand.word1}
        word2={settings.brand.word2}
        graffiti="layered"
        layout="inline"
        size={18}
        gangSize={22}
        rotate={-4}
      />
    </a>

    {
      active === 'templates' && (
        <button
          type="button"
          id="tpl-global-reset"
          class="header-reset"
          aria-label="Скинути всі зміни шаблонів"
          hidden
        >
          Скинути все
        </button>
      )
    }

    <nav class="site-nav">
      {
        active === 'templates' ? (
          <Fragment>
            <span class="nav-tag">ШАБЛОНИ INSTAGRAM</span>
            <a href="/" class="nav-link">← НА ГОЛОВНУ</a>
          </Fragment>
        ) : (
          <Fragment>
            {settings.nav.map((n) => (
              <a href={n.href} class="nav-link">
                {n.label}
              </a>
            ))}
            {jarActive && (
              <a
                href={settings.cta.href}
                class="btn btn-primary btn--sm"
                data-track="cta_click"
                data-evt-cta-location="header"
              >
                {settings.cta.label}
              </a>
            )}
          </Fragment>
        )
      }
    </nav>
  </div>
</header>
