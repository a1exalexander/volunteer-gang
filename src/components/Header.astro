---
import type { CollectionEntry } from 'astro:content';
import Logo from './brand/Logo.astro';

interface Props {
  active?: 'home' | 'templates';
  settings: CollectionEntry<'site'>['data'];
  ui: CollectionEntry<'ui'>['data'];
}

const { active, settings, ui } = Astro.props;
---

<header class="site-header">
  <div class="container site-header-inner">
    <a href="/" class="logo" aria-label={`${settings.brand.word1} ${settings.brand.word2}`}>
      <Logo
        word1={settings.brand.word1}
        word2={settings.brand.word2}
        graffiti="layered"
        layout="inline"
        size={18}
        gangSize={22}
        rotate={-4}
      />
    </a>

    <nav class:list={['site-nav', active !== 'templates' && 'site-nav--collapsible']} id="site-nav">
      {
        active === 'templates' ? (
          <Fragment>
            <span class="nav-tag">{ui.templatesHeaderTag}</span>
            <a href="/" class="nav-link">{ui.backHomeLabel}</a>
          </Fragment>
        ) : (
          <Fragment>
            {settings.nav.map((n) => (
              <a href={n.href} class="nav-link">
                {n.label}
              </a>
            ))}
            <a
              href={settings.cta.href}
              class="btn btn-primary btn--sm"
              data-track="cta_click"
              data-evt-cta-location="header"
            >
              {settings.cta.label}
            </a>
          </Fragment>
        )
      }
    </nav>

    {
      active !== 'templates' && (
        <button
          type="button"
          class="nav-burger"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label={ui.menuToggleAriaLabel}
        >
          <span class="nav-burger-bar" />
          <span class="nav-burger-bar" />
          <span class="nav-burger-bar" />
        </button>
      )
    }
  </div>
</header>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.nav-burger');
  const nav = document.getElementById('site-nav');
  if (burger && nav) {
    const setOpen = (open: boolean) => {
      nav.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
    };
    burger.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')));
    // Anchor links keep the page in place, so collapse the menu ourselves.
    nav.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
</script>

{
  /* Lives outside <header>: its backdrop-filter would otherwise become the
     containing block for the pill's `position: fixed` (used on both desktop,
     where it's centred over the header, and mobile, where it anchors to the
     bottom of the viewport — see .header-reset in vg.css). */
  active === 'templates' && (
    <button
      type="button"
      id="tpl-global-reset"
      class="header-reset"
      aria-label={ui.templatesResetAllAriaLabel}
      hidden
    >
      <span data-tpl-reset-all-label>{ui.templatesResetAllLabel}</span>
    </button>
  )
}
