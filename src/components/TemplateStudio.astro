---
import type { CollectionEntry } from 'astro:content';
import { fmtUAH, percentOf, dayFmt } from '../lib/format';
import React from 'react';
import type { IconType } from 'react-icons';
import { renderToStaticMarkup } from 'react-dom/server';
import { FiAlertTriangle, FiCheck, FiCheckCircle, FiCopy, FiDownload, FiEdit3, FiRotateCcw, FiTrash2 } from 'react-icons/fi';
import TemplateLockup from './brand/TemplateLockup.astro';
import TplPhotoSlot from './TplPhotoSlot.astro';

interface Props {
  fund: CollectionEntry<'fundraiser'>['data'];
}
const { fund } = Astro.props;

// Server-rendered initial values so the canvases look correct before the
// client script hydrates. The client then merges any localStorage overrides.
const percent = percentOf(fund.raised, fund.goal);
const raisedFmt = fmtUAH(fund.raised);
const goalFmt = fmtUAH(fund.goal);
const remainingFmt = fmtUAH(Math.max(0, fund.goal - fund.raised));
const dayFmtStr = dayFmt(fund.day);

const initial = {
  day: fund.day,
  titleMain: fund.titleMain,
  titleAccent: fund.titleAccent,
  desc: fund.desc,
  goal: fund.goal,
  raised: fund.raised,
  photo: null,
};

const iconMarkup = (icon: IconType) =>
  renderToStaticMarkup(
    React.createElement(icon, {
      size: 14,
      'aria-hidden': true,
      focusable: false,
    })
  );

const actionIcons = {
  download: iconMarkup(FiDownload),
  copy: iconMarkup(FiCopy),
  edit: iconMarkup(FiEdit3),
  done: iconMarkup(FiCheck),
  reset: iconMarkup(FiRotateCcw),
  remove: iconMarkup(FiTrash2),
  // Feedback icons paired with the success/error action tooltips
  // («Збережено» / «Скопійовано» vs. their «Помилка …» variants).
  success: iconMarkup(FiCheckCircle),
  error: iconMarkup(FiAlertTriangle),
};
---

<div class="studio">
  <!-- Mobile-only: floating opener + backdrop for the fields drawer -->
  <button type="button" id="studio-drawer-toggle" class="drawer-toggle" aria-controls="studio-panel" aria-expanded="false">✎ ДАНІ ЗБОРУ</button>
  <div id="studio-drawer-backdrop" class="drawer-backdrop"></div>

  <!-- ============ FIELDS PANEL ============ -->
  <aside id="studio-panel" class="studio-panel" aria-label="Дані збору">
    <div class="drawer-head">
      <span class="drawer-grip" aria-hidden="true"></span>
      <button type="button" id="studio-drawer-close" class="drawer-close" aria-label="Закрити панель">✕</button>
    </div>

    <div class="field">
      <h1 class="panel-title">Дані збору</h1>
      <p class="panel-intro">
        Заповни один раз — оновляться всі шаблони. Потім «PNG» або «Копіювати» під потрібним.
      </p>
    </div>

    <div class="field">
      <label class="field-label" for="tpl-day">ДЕНЬ ЗБОРУ</label>
      <input class="input" id="tpl-day" type="number" value={fund.day} />
    </div>

    <div class="field">
      <label class="field-label" for="tpl-titleMain">ЗАГОЛОВОК (рядки — з нового рядка)</label>
      <textarea class="input" id="tpl-titleMain" rows="2">{fund.titleMain}</textarea>
    </div>

    <div class="field">
      <label class="field-label" for="tpl-titleAccent">АКЦЕНТНИЙ РЯДОК (бригада / підрозділ)</label>
      <input class="input input--accent" id="tpl-titleAccent" type="text" value={fund.titleAccent} />
    </div>

    <div class="field">
      <label class="field-label" for="tpl-desc">ОПИС</label>
      <textarea class="input" id="tpl-desc" rows="3">{fund.desc}</textarea>
    </div>

    <div class="field-row">
      <div class="field">
        <label class="field-label" for="tpl-goal">ЦІЛЬ, ₴</label>
        <input class="input" id="tpl-goal" type="number" value={fund.goal} />
      </div>
      <div class="field">
        <label class="field-label" for="tpl-raised">ЗІБРАНО, ₴</label>
        <input class="input" id="tpl-raised" type="number" value={fund.raised} />
      </div>
    </div>

    <div class="panel-bar"><span data-bar style={`width:${percent}%`}></span></div>
    <div class="panel-figures">
      <span class="raised" data-bind="raisedFmt">{raisedFmt}</span>
      <span><span data-bind="percent">{percent}</span>%</span>
      <span data-bind="goalFmt">{goalFmt}</span>
    </div>

    <div class="panel-photo">
      <span class="field-label">ФОТО · ОДНЕ ДЛЯ ВСІХ ШАБЛОНІВ (за бажанням)</span>
      <label class="dropzone" id="tpl-photo-drop">
        <input id="tpl-photo" type="file" accept="image/*" class="dropzone-input" />
        <span class="dropzone-thumb" id="tpl-photo-thumb" aria-hidden="true"></span>
        <span class="dropzone-body">
          <svg class="dropzone-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span class="dropzone-text dropzone-text--empty">
            <span class="dropzone-title">Перетягни фото сюди</span>
            <span class="dropzone-hint">або натисни, щоб обрати</span>
          </span>
          <span class="dropzone-text dropzone-text--filled">
            <span class="dropzone-title">Фото завантажено</span>
            <span class="dropzone-hint">натисни або перетягни, щоб замінити</span>
          </span>
        </span>
      </label>
      <div class="panel-photo-row">
        <button type="button" id="tpl-photo-clear" class="ghost-btn" style="display:none">✕ Прибрати</button>
      </div>
    </div>

    <div class="panel-colors">
      <div class="panel-colors-head">
        <span class="field-label">КОЛЬОРИ ШАБЛОНІВ</span>
        <button type="button" id="tpl-colors-reset" class="ghost-btn ghost-btn--mini">↺ Скинути</button>
      </div>
      <div class="swatch-grid">
        <label class="swatch"><input type="color" data-color="ink" value="#0d0c0c" /><span>Фон</span></label>
        <label class="swatch"><input type="color" data-color="chalk" value="#f5f1ec" /><span>Світлий</span></label>
        <label class="swatch"><input type="color" data-color="pink" value="#ff2e88" /><span>Основний</span></label>
        <label class="swatch"><input type="color" data-color="acid" value="#c9e400" /><span>Акцент</span></label>
        <label class="swatch"><input type="color" data-color="bubble" value="#f4a6e3" /><span>Бабл</span></label>
      </div>
    </div>
  </aside>

  <!-- ============ GALLERY ============ -->
  <main class="gallery">
    <div class="studio-alert" role="note">
      <svg class="studio-alert-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
      <p>
        <strong>Фото — за бажанням.</strong> Пунктирне місце під фото видно лише у прев'ю: якщо фото не завантажено,
        шаблон скачається або скопіюється <strong>без цього плейсхолдера</strong>.
      </p>
    </div>

    <!-- POST: ANNOUNCE -->
    <div class="tpl">
      <div class="tpl-cap">ПОСТ · АНОНС ЗБОРУ · 1080×1080</div>
      <div class="tpl-preview" style="width:356px;height:356px;border:1px solid var(--c-line);">
        <div class="tpl-scale">
          <div id="vgx-announce" class="canvas" style="width:1080px;height:1080px;background:var(--c-ink);padding:80px;display:flex;flex-direction:column;justify-content:space-between;overflow:hidden;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;position:relative;">
              <TemplateLockup layout="stack" color="var(--c-chalk)" vSize={30} gSize={34} rotate={-5} />
            </div>
            <div style="display:flex;gap:44px;align-items:stretch;position:relative;">
              <div style="flex:1;display:flex;flex-direction:column;gap:28px;justify-content:center;min-width:0;">
                <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:80px;line-height:1;color:var(--c-chalk);"><span style="white-space:pre-line;" data-bind="titleMain">{fund.titleMain}</span><br /><span style="color:var(--c-bubble);" data-bind="titleAccent">{fund.titleAccent}</span></div>
                <p style="margin:0;font-size:30px;line-height:1.5;color:var(--c-dust);" data-bind="desc">{fund.desc}</p>
              </div>
              <div data-export-optional="photo" style="width:360px;flex-shrink:0;position:relative;border:8px solid var(--c-bubble);overflow:hidden;">
                <div role="img" aria-label="Фото товару" data-photo style="position:absolute;inset:0;background-size:contain;background-position:center;background-repeat:no-repeat;display:none;"></div>
                <div data-nophoto style="position:absolute;inset:0;background:repeating-linear-gradient(45deg,var(--c-panel2),var(--c-panel2) 20px,var(--c-ink) 20px,var(--c-ink) 40px);display:flex;align-items:center;justify-content:center;text-align:center;padding:24px;">
                  <span style="font-family:'IBM Plex Mono',monospace;font-size:24px;color:var(--c-dust);line-height:1.5;">ФОТО<br />ЩО КУПУЄМО<br /><span style="font-size:18px;">· за бажанням ·</span></span>
                </div>
                <div style="position:absolute;left:0;bottom:0;background:var(--c-bubble);color:var(--c-ink);font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:500;padding:10px 18px;letter-spacing:0.08em;">ЗБІР НА ↓</div>
              </div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;position:relative;">
              <div style="background:var(--c-bubble);color:var(--c-ink);font-family:'Unbounded',sans-serif;font-weight:800;font-size:34px;padding:28px 44px;">Ціль: <span data-bind="goalFmt">{goalFmt}</span></div>
              <div style="font-family:'IBM Plex Mono',monospace;font-size:24px;color:var(--c-dust);">банка → лінк у біо</div>
            </div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="announce">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="announce">⧉ Копіювати</button>
        <span class="tpl-status" data-status="announce"></span>
      </div>
    </div>

    <!-- STORY: PROGRESS -->
    <div class="tpl">
      <div class="tpl-cap">СТОРІЗ · ПРОГРЕС · 1080×1350</div>
      <div class="tpl-preview" style="width:356px;height:445px;border:1px solid var(--c-line);">
        <div class="tpl-scale">
          <div id="vgx-progress" class="canvas" style="width:1080px;height:1350px;background:var(--c-ink);padding:114px 100px;display:flex;flex-direction:column;justify-content:space-between;">
            <TplPhotoSlot pos="top:310px;right:100px;" size={300} rotate={4} frame="var(--c-bubble)" />
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <TemplateLockup layout="inline" color="var(--c-chalk)" vSize={34} gSize={38} />
              <div style="display:flex;gap:14px;">
                <div style="width:50px;height:36px;background:var(--c-bubble);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
                <div style="width:50px;height:36px;background:var(--c-bubble);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:56px;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:39px;letter-spacing:0.2em;color:var(--c-dust);">АКТИВНИЙ ЗБІР · ДЕНЬ <span data-bind="day">{fund.day}</span></div>
              <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:107px;line-height:1.05;color:var(--c-chalk);">Уже<br /><span data-bind="percent">{percent}</span>%</div>
              <div style="height:50px;background:var(--c-line);position:relative;"><span data-bar style={`position:absolute;inset:0;background:var(--c-bubble);width:${percent}%`}></span></div>
              <div style="display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:43px;color:var(--c-dust);">
                <span style="color:var(--c-bubble);font-weight:500;" data-bind="raisedFmt">{raisedFmt}</span>
                <span data-bind="goalFmt">{goalFmt}</span>
              </div>
              <div style="border:6px dashed rgba(245,241,236,0.45);border-radius:80px;padding:34px 40px;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:34px;letter-spacing:0.1em;color:var(--c-dust);">🔗 МІСЦЕ ДЛЯ ЛІНК-СТІКЕРА</div>
            </div>
            <div style="background:var(--c-chalk);color:var(--c-ink);font-family:'Unbounded',sans-serif;font-weight:800;font-size:46px;text-align:center;padding:50px;">Докинути в банку ↑</div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="progress">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="progress">⧉ Копіювати</button>
        <span class="tpl-status" data-status="progress"></span>
      </div>
    </div>

    <!-- POST: URGENT -->
    <div class="tpl">
      <div class="tpl-cap">ПОСТ · ТЕРМІНОВИЙ ЗБІР · 1080×1080</div>
      <div class="tpl-preview" style="width:356px;height:356px;">
        <div class="tpl-scale">
          <div id="vgx-urgent" class="canvas" style="width:1080px;height:1080px;background:var(--c-ink);border:28px solid var(--c-bubble);padding:72px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <TemplateLockup layout="inline" color="var(--c-chalk)" vSize={30} gSize={32} />
              <div style="display:flex;gap:10px;">
                <div style="width:36px;height:26px;background:var(--c-bubble);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
                <div style="width:36px;height:26px;background:var(--c-bubble);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:32px;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:26px;letter-spacing:0.24em;color:var(--c-acid);">ТЕРМІНОВО · ЗБІР</div>
              <div style="display:flex;gap:40px;align-items:stretch;">
                <div style="flex:1;display:flex;flex-direction:column;gap:30px;justify-content:center;min-width:0;">
                  <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:88px;line-height:0.98;color:var(--c-chalk);"><span style="white-space:pre-line;" data-bind="titleMain">{fund.titleMain}</span><br /><span style="color:transparent;-webkit-text-stroke:3px var(--c-acid);" data-bind="titleAccent">{fund.titleAccent}</span></div>
                  <p style="margin:0;font-size:30px;line-height:1.5;color:var(--c-dust);" data-bind="desc">{fund.desc}</p>
                </div>
                <div data-export-optional="photo" style="width:320px;flex-shrink:0;position:relative;border:8px solid var(--c-acid);overflow:hidden;">
                  <div role="img" aria-label="Фото товару" data-photo style="position:absolute;inset:0;background-size:contain;background-position:center;background-repeat:no-repeat;display:none;"></div>
                  <div data-nophoto style="position:absolute;inset:0;background:repeating-linear-gradient(45deg,var(--c-panel2),var(--c-panel2) 20px,var(--c-ink) 20px,var(--c-ink) 40px);display:flex;align-items:center;justify-content:center;text-align:center;padding:24px;">
                    <span style="font-family:'IBM Plex Mono',monospace;font-size:24px;color:var(--c-dust);line-height:1.5;">ФОТО<br />ЩО КУПУЄМО<br /><span style="font-size:18px;">· за бажанням ·</span></span>
                  </div>
                  <div style="position:absolute;left:0;bottom:0;background:var(--c-acid);color:var(--c-ink);font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:500;padding:10px 18px;letter-spacing:0.08em;">ЗБІР НА ↓</div>
                </div>
              </div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <div style="background:var(--c-chalk);color:var(--c-ink);font-family:'Unbounded',sans-serif;font-weight:800;font-size:32px;padding:26px 40px;">Ціль: <span data-bind="goalFmt">{goalFmt}</span></div>
              <div style="font-family:'IBM Plex Mono',monospace;font-size:24px;color:var(--c-dust);">банка → лінк у біо</div>
            </div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="urgent">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="urgent">⧉ Копіювати</button>
        <span class="tpl-status" data-status="urgent"></span>
      </div>
    </div>

    <!-- STORY: LAST PUSH -->
    <div class="tpl">
      <div class="tpl-cap">СТОРІЗ · ОСТАННІЙ РИВОК · 1080×1350</div>
      <div class="tpl-preview" style="width:356px;height:445px;">
        <div class="tpl-scale">
          <div id="vgx-push" class="canvas" style="width:1080px;height:1350px;background:var(--c-bubble);padding:114px 100px;display:flex;flex-direction:column;justify-content:space-between;">
            <TplPhotoSlot pos="top:330px;right:96px;" size={300} rotate={-5} frame="var(--c-ink)" />
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <TemplateLockup layout="inline" color="var(--c-ink)" vSize={34} gSize={38} />
              <div style="font-family:'IBM Plex Mono',monospace;font-size:39px;letter-spacing:0.18em;color:var(--c-ink);">ДЕНЬ <span data-bind="day">{fund.day}</span></div>
            </div>
            <div style="display:flex;flex-direction:column;gap:50px;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:156px;line-height:0.98;color:var(--c-ink);">Останній<br />ривок</div>
              <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:107px;line-height:1;color:transparent;-webkit-text-stroke:4px var(--c-ink);">лишилось</div>
              <div style="font-family:'IBM Plex Mono',monospace;font-size:92px;font-weight:500;color:var(--c-ink);" data-bind="remainingFmt">{remainingFmt}</div>
              <div style="border:6px dashed rgba(13,12,12,0.5);border-radius:80px;padding:34px 40px;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:34px;letter-spacing:0.1em;color:rgba(13,12,12,0.6);">🔗 МІСЦЕ ДЛЯ ЛІНК-СТІКЕРА</div>
            </div>
            <div style="background:var(--c-ink);color:var(--c-bubble);font-family:'Unbounded',sans-serif;font-weight:800;font-size:46px;text-align:center;padding:50px;">Закриваємо сьогодні ↑</div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="push">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="push">⧉ Копіювати</button>
        <span class="tpl-status" data-status="push"></span>
      </div>
    </div>

    <!-- POST: PHOTO REPORT -->
    <div class="tpl">
      <div class="tpl-cap">ПОСТ · ФОТОЗВІТ · 1080×1080</div>
      <div class="tpl-preview" style="width:356px;height:356px;">
        <div class="tpl-scale">
          <div id="vgx-report" class="canvas" style="width:1080px;height:1080px;background:var(--c-bubble);padding:80px;display:flex;flex-direction:column;gap:48px;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:30px;color:var(--c-ink);">VOLUNTEER GANG · ЗВІТ</div>
              <div style="background:var(--c-ink);color:var(--c-bubble);font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:500;padding:12px 20px;letter-spacing:0.12em;">ЧЕКИ ✓ ФОТО ✓</div>
            </div>
            <div style="flex:1;position:relative;min-height:0;">
              <div role="img" aria-label="Фото передачі" data-photo style="position:absolute;inset:0;background-size:contain;background-position:center;background-repeat:no-repeat;display:none;"></div>
              <div data-nophoto data-export-optional="photo" style="position:absolute;inset:0;border:4px dashed rgba(13,12,12,0.55);background:repeating-linear-gradient(45deg,var(--c-bubble),var(--c-bubble) 24px,var(--c-bubble2) 24px,var(--c-bubble2) 48px);display:flex;align-items:center;justify-content:center;">
                <span style="font-family:'IBM Plex Mono',monospace;font-size:26px;color:rgba(13,12,12,0.55);">фото передачі бригаді · за бажанням</span>
              </div>
              <div style="position:absolute;bottom:-28px;right:40px;background:var(--c-bubble);color:var(--c-ink);font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:32px;padding:20px 32px;transform:rotate(-3deg);">ПЕРЕДАНО</div>
