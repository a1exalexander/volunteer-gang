            </div>
            <div style="height:40px;background:var(--c-line);position:relative;"><span data-bar style={`position:absolute;inset:0;background:var(--c-pink);width:${percent}%`}></span></div>
            <p style="margin:0;font-family:'IBM Plex Mono',monospace;font-size:30px;line-height:1.5;color:var(--c-dust);" data-bind="desc">{fund.desc}</p>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="weekly">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="weekly">⧉ Копіювати</button>
        <span class="tpl-status" data-status="weekly"></span>
      </div>
    </div>

    <!-- POST: QUOTE -->
    <div class="tpl">
      <div class="tpl-cap">ПОСТ · СЛОВО ВІД НАС · 1080×1080</div>
      <div class="tpl-preview" style="width:356px;height:356px;border:1px solid var(--c-line);">
        <div class="tpl-scale">
          <div id="vgx-quote" class="canvas" style="width:1080px;height:1080px;background:var(--c-ink);padding:80px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="font-family:'Sedgwick Ave Display',cursive;font-size:220px;line-height:0.7;color:var(--c-pink);">«</div>
            <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.01em;font-size:72px;line-height:1.15;color:var(--c-chalk);max-width:820px;" data-bind="desc">{fund.desc}</div>
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:30px;color:var(--c-pink);letter-spacing:0.1em;" data-bind="titleAccent">{fund.titleAccent}</div>
              <TemplateLockup layout="inline" color="var(--c-chalk)" vSize={30} gSize={34} />
            </div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="quote">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="quote">⧉ Копіювати</button>
        <span class="tpl-status" data-status="quote"></span>
      </div>
    </div>

    <!-- POST: MINIMAL -->
    <div class="tpl">
      <div class="tpl-cap">ПОСТ · МІНІМАЛ · 1080×1080</div>
      <div class="tpl-preview" style="width:356px;height:356px;">
        <div class="tpl-scale">
          <div id="vgx-minimal" class="canvas" style="width:1080px;height:1080px;background:var(--c-chalk);padding:80px;display:flex;flex-direction:column;justify-content:space-between;">
            <TemplateLockup layout="inline" color="var(--c-ink)" vSize={30} gSize={34} />
            <div style="display:flex;flex-direction:column;gap:28px;align-items:flex-start;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:150px;line-height:0.95;color:var(--c-ink);white-space:pre-line;" data-bind="titleMain">{fund.titleMain}</div>
              <div style="background:var(--c-acid);color:var(--c-ink);font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:64px;padding:12px 28px;transform:rotate(-2deg);" data-bind="titleAccent">{fund.titleAccent}</div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;font-family:'IBM Plex Mono',monospace;font-size:28px;color:var(--c-ink);">
              <span>Ціль: <span data-bind="goalFmt">{goalFmt}</span></span>
              <span>банка → лінк у біо</span>
            </div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="minimal">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="minimal">⧉ Копіювати</button>
        <span class="tpl-status" data-status="minimal"></span>
      </div>
    </div>

    <!-- STORY: SOS -->
    <div class="tpl">
      <div class="tpl-cap">СТОРІЗ · SOS · 1080×1920</div>
      <div class="tpl-preview" style="width:356px;height:633px;">
        <div class="tpl-scale">
          <div id="vgx-sos" class="canvas" style="width:1080px;height:1920px;background:var(--c-pink);padding:100px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:110px;line-height:0.98;color:var(--c-ink);">
              <div>ТЕРМІНОВО</div>
              <div style="color:transparent;-webkit-text-stroke:3px var(--c-ink);">ТЕРМІНОВО</div>
              <div>ТЕРМІНОВО</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:40px;">
              <div style="background:var(--c-ink);padding:56px;display:flex;flex-direction:column;gap:32px;">
                <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:96px;line-height:1;color:var(--c-chalk);"><span style="white-space:pre-line;" data-bind="titleMain">{fund.titleMain}</span></div>
                <div style="font-family:'IBM Plex Mono',monospace;font-size:52px;font-weight:500;color:var(--c-pink);">лишилось <span data-bind="remainingFmt">{remainingFmt}</span></div>
              </div>
              <div style="border:6px dashed rgba(13,12,12,0.5);border-radius:80px;padding:34px 40px;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:34px;letter-spacing:0.1em;color:rgba(13,12,12,0.6);">🔗 МІСЦЕ ДЛЯ ЛІНК-СТІКЕРА</div>
            </div>
            <div style="background:var(--c-ink);color:var(--c-pink);font-family:'Unbounded',sans-serif;font-weight:800;font-size:46px;text-align:center;padding:50px;">Закриваємо зараз ↑</div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="sos">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="sos">⧉ Копіювати</button>
        <span class="tpl-status" data-status="sos"></span>
      </div>
    </div>

    <!-- STORY: CLOSED -->
    <div class="tpl">
      <div class="tpl-cap">СТОРІЗ · ЗАКРИТО · 1080×1920</div>
      <div class="tpl-preview" style="width:356px;height:633px;">
        <div class="tpl-scale">
          <div id="vgx-closedstory" class="canvas" style="width:1080px;height:1920px;background:var(--c-acid);padding:114px 100px;display:flex;flex-direction:column;justify-content:space-between;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <TemplateMonogram size={53} color="var(--c-ink)" />
              <TemplateGang gSize={56} rotate={-4} />
            </div>
            <div style="display:flex;flex-direction:column;gap:70px;align-items:flex-start;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;letter-spacing:0.02em;font-size:130px;line-height:1;color:var(--c-ink);transform:rotate(-6deg);border:14px solid var(--c-ink);padding:36px 54px;">ЗАКРИТО ✕</div>
              <div style="font-family:'IBM Plex Mono',monospace;font-size:52px;line-height:1.6;color:var(--c-ink);">Зібрано <span data-bind="goalFmt">{goalFmt}</span> · за <span data-bind="dayFmt">{dayFmtStr}</span><br />звіт — уже скоро</div>
            </div>
            <div style="display:flex;gap:18px;">
              <div style="width:64px;height:46px;background:var(--c-ink);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
              <div style="width:64px;height:46px;background:var(--c-ink);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
              <div style="width:64px;height:46px;background:var(--c-ink);clip-path:polygon(50% 0,100% 45%,100% 100%,50% 55%,0 100%,0 45%);"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="tpl-actions">
        <button type="button" class="dl-btn" data-dl="closedstory">↓ PNG</button>
        <button type="button" class="cp-btn" data-cp="closedstory">⧉ Копіювати</button>
        <span class="tpl-status" data-status="closedstory"></span>
      </div>
    </div>
  </main>
</div>

