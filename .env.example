# Google Analytics 4 measurement ID. Set this in Netlify → Site config →
# Environment variables. If unset, analytics is disabled (no GA script loads).
PUBLIC_GA_ID=

# Set to 1 to force-load GA in local dev with debug_mode (events show in GA4
# DebugView). Leave unset normally so localhost traffic is NOT tracked.
# PUBLIC_GA_DEBUG=1

# Canonical site origin used for absolute URLs (canonical, OG, sitemap).
# Defaults to https://volunteer-gang.netlify.app when unset.
# SITE=https://volunteer-gang.example
